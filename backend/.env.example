# Backend .env — NEVER commit this file
# Store real values only on your backend server or hosting platform (Vercel, Railway, etc.)

# Paystack (Secret keys only)
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here

# DHL (Backend delivery logistics)
DHL_SUBSCRIPTION_KEY=your_subscription_key_here
