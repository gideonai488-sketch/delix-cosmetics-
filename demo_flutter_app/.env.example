# -----------------------------
# Client-side (Flutter app)
# -----------------------------
# Safe to expose to client bundle.
APP_API_BASE_URL=https://your-api-domain.com
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------
# Server-side only (DO NOT expose in Flutter app)
# Keep these in your backend .env, not in mobile/web app builds.
# -----------------------------
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
DHL_SUBSCRIPTION_KEY=
DHL_SECRET_KEY=
# Optional: only if required by your DHL integration/package.
DHL_ACCOUNT_NUMBER=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
PAYSTACK_CALLBACK_URL=https://your-frontend-domain.com/payment/callback
